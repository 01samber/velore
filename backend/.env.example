PORT=3000
NODE_ENV=development

# Local Docker Postgres (recommended for team dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/velore?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/velore?schema=public

JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d
AI_SERVICE_URL=http://localhost:5001
FRONTEND_URL=http://localhost:5173

# Stripe (required if enabling /api/v1/payments endpoints)
STRIPE_SECRET_KEY=

# Email (required if enabling forgot/reset password email)
GMAIL_USER=
GMAIL_APP_PASSWORD=